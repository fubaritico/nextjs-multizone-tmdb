# ============================================================================
# Production Environment Variables (Netlify)
# ============================================================================
# Set these in Netlify UI: Site Settings → Environment Variables
# DO NOT commit this file with real values
# ============================================================================

# ============================================================================
# Multi-Zone URLs (Netlify Deployments)
# ============================================================================
# Replace with actual Netlify deployment URLs for each zone
NEXT_PUBLIC_HOME_URL=https://your-home-zone.netlify.app
NEXT_PUBLIC_MEDIA_URL=https://your-media-zone.netlify.app
NEXT_PUBLIC_TALENTS_URL=https://your-talents-zone.netlify.app
NEXT_PUBLIC_SEARCH_URL=https://your-search-zone.netlify.app

# ============================================================================
# API Keys (Production)
# ============================================================================

# TMDB API Token
# VITE_ prefix kept for compatibility with @fubar-it-co/tmdb-client
VITE_TMDB_API_TOKEN=your_production_token_here

# ============================================================================
# Build Tools
# ============================================================================

# npm registry auth
NPM_TOKEN=your_npm_token_here

# SonarCloud
SONAR_TOKEN=your_sonar_token_here