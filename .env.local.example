# ============================================================================
# Local Development Environment Variables
# ============================================================================
# Copy this file to .env.local for local development
# .env.local is gitignored and will override .env values
#
# Usage: cp .env.local.example .env.local
# ============================================================================

# ============================================================================
# Multi-Zone URLs (development)
# ============================================================================
# Used by apps/web for rewrites to zone apps
NEXT_PUBLIC_HOME_URL=http://localhost:3001
NEXT_PUBLIC_MEDIA_URL=http://localhost:3002
NEXT_PUBLIC_TALENTS_URL=http://localhost:3003
NEXT_PUBLIC_SEARCH_URL=http://localhost:3004

# ============================================================================
# API Keys (Development)
# ============================================================================

# TMDB API Token (get yours at https://www.themoviedb.org/settings/api)
# VITE_ prefix kept for compatibility with @fubar-it-co/tmdb-client
VITE_TMDB_API_TOKEN=your_token_here

# ============================================================================
# Build Tools
# ============================================================================

# npm registry auth (used by .npmrc for @fubar-it-co / @vite-mf-monorepo scopes)
NPM_TOKEN=your_npm_token_here