{
  "name": "nextjs-multizone-tmdb",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "dev": "turbo dev",
    "start": "turbo start",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "eslint --fix",
